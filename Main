<script>
const RUST  = '#c44b2b';
const RUST2 = '#e06848';
const SAND  = '#d4a96a';
const SAGE  = '#5c7a5c';
const SAGE2 = '#7a9a7a';
const CLAY  = '#8a5a3c';
const NAVY  = '#1e2a3a';
const PAPER = '#f4f0e8';
const BONE  = '#ede8df';

// ─── PIE CHART ───────────────────────────────────────────────
new Chart(document.getElementById('pieChart'), {
  type: 'doughnut',
  data: {
    labels: ['US Total Market 60%','International 25%','Small Cap Value 10%','Bonds 5%'],
    datasets: [{ data:[60,25,10,5],
      backgroundColor:[RUST,NAVY,SAND,SAGE],
      borderColor:'#fff', borderWidth:3
    }]
  },
  options:{ cutout:'62%', plugins:{ legend:{ position:'right', labels:{ font:{family:'Jost',size:11}, color:'#5a4a38', padding:10 } } } }
});

// ─── PROJECTION DATA ─────────────────────────────────────────
// Real dollars, 7% real return, lifestyle-forward savings rate
// Contributions are lower than Plan B; more goes to living
const PHASES = {
  23:'Foundation', 24:'Foundation',
  25:'DINK Surge', 26:'DINK Surge', 27:'DINK Surge',
  28:'Kid 1 + House', 29:'Kid 2 + Family', 30:'Family — Daycare',
  31:'Family — Peak', 32:'Family — Declining', 33:'Family — Declining',
  34:'Re-Acceleration', 35:'Re-Acceleration', 36:'Re-Acceleration',
  37:'Re-Acceleration', 38:'Peak Saving', 39:'Peak Saving',
  40:'Peak Saving', 41:'Peak Saving', 42:'Peak Saving',
  43:'Peak Saving', 44:'Peak Saving', 45:'Peak Saving',
  46:'Peak Saving', 47:'Peak — 529 wind-down', 48:'Peak Saving',
  49:'Peak Saving', 50:'Peak Saving', 51:'Peak Saving',
  52:'Peak Saving', 53:'Peak Saving', 54:'Peak Saving',
  55:'Final Stretch', 56:'Final Stretch', 57:'Final Stretch',
  58:'Final Stretch', 59:'Final Stretch',
  60:'Both Retired', 61:'Both Retired', 62:'Both Retired',
  63:'Both Retired', 64:'Both Retired', 65:'Both Retired'
};

// Lower contributions — more going to lifestyle, travel, fun
const CONTRIBS = {
  23: 13000, 24: 28000,
  25: 42000, 26: 44000, 27: 40000,   // house saving; DINK years
  28: 30000, 29: 26000, 30: 24000,   // kid 1 arrives, house, kid 2
  31: 22000, 32: 28000, 33: 32000,   // daycare declining
  34: 42000, 35: 50000, 36: 54000,   // daycare ends; re-accel
  37: 58000, 38: 62000, 39: 64000,
  40: 66000, 41: 68000, 42: 70000,
  43: 71000, 44: 73000, 45: 74000,
  46: 75000, 47: 72000, 48: 73000,   // 529 wind-down; keep investing
  49: 74000, 50: 75000, 51: 74000,
  52: 76000, 53: 76000, 54: 75000,
  55: 70000, 56: 68000, 57: 65000,
  58: 60000, 59: 55000,
  60: -95000, 61: -97000, 62: -99000, 63: -101000, 64: -103000, 65: -90000
};

const fK = n => { const a=Math.abs(n); if(a>=1e6) return (n<0?'-':'')+'$'+(a/1e6).toFixed(2)+'M'; return (n<0?'-':'')+'$'+Math.round(a/1000)+'K'; };
const fM = n => '$'+(n/1e6).toFixed(2)+'M';

const rows = [];
let port = 20000;
for(let age=23; age<=65; age++){
  const c = CONTRIBS[age];
  const bStart = port;
  const growth = Math.round((bStart + c/2) * 0.07);
  port = bStart + c + growth;
  rows.push({age, year:2026+(age-23), phase:PHASES[age], c, bStart, growth, bEnd:port});
}

// Populate table
const tbody = document.getElementById('projTable');
rows.forEach(r=>{
  const isMile = [35,45,55,60,65].includes(r.age);
  const isOut  = r.c < 0;
  const mileLbl =
    r.age===35 ? ' ✓ Daycare Over' :
    r.age===45 ? ' ✓ Halfway' :
    r.age===55 ? ' Final Stretch' :
    r.age===60 ? ' 🌅 Both Retire' :
    r.age===65 ? ' Medicare' : '';
  tbody.innerHTML += `<tr class="${r.age===60?'tr-tot':isMile?'tr-tot':''}">
    <td>${r.age}${mileLbl?`<strong style="color:var(--rust)"> ${mileLbl}</strong>`:''}
    </td>
    <td>${r.year}</td>
    <td style="font-size:11.5px;color:var(--text-l)">${r.phase}</td>
    <td class="r ${isOut?'rd':'sd'}">${fK(r.c)}</td>
    <td class="r">${r.bStart>=1e6?fM(r.bStart):fK(r.bStart)}</td>
    <td class="r g">${fK(r.growth)}</td>
    <td class="r" style="font-weight:600;color:var(--ink)">${r.bEnd>=1e6?fM(r.bEnd):fK(r.bEnd)}</td>
  </tr>`;
});

const at = age => rows.find(r=>r.age===age).bEnd;
document.getElementById('p35').textContent  = fM(at(35));
document.getElementById('p45').textContent  = fM(at(45));
document.getElementById('p55').textContent  = fM(at(55));
document.getElementById('p60').textContent  = fM(at(60));
document.getElementById('swr60').textContent= '$'+Math.round(at(60)*0.035/1000)+'K/yr';
document.getElementById('p65').textContent  = fM(at(65));

// Growth chart
const labels = rows.map(r=>`${r.age}`);
const portVals = rows.map(r=>r.bEnd);
const growthVals = rows.map(r=>r.growth);
const contribVals = rows.map(r=>r.c);

new Chart(document.getElementById('growthChart'),{
  type:'line',
  data:{ labels,
    datasets:[{
      label:'Portfolio (Real $)',
      data:portVals,
      borderColor:RUST,
      backgroundColor:'rgba(196,75,43,0.06)',
      borderWidth:3, fill:true, tension:0.4,
      pointRadius:portVals.map((_,i)=>[12,22,32,37].includes(i)?6:2),
      pointBackgroundColor:portVals.map((_,i)=>[37-23].includes(i)?SAND:RUST),
    }]
  },
  options:{
    responsive:true,
    plugins:{
      legend:{display:false},
      tooltip:{callbacks:{label:ctx=>` Portfolio: ${ctx.raw>=1e6?fM(ctx.raw):fK(ctx.raw)}`}}
    },
    scales:{
      y:{grid:{color:'rgba(0,0,0,0.04)'}, ticks:{callback:v=>v>=1e6?fM(v):fK(v), font:{family:'Fira Mono',size:10}}},
      x:{grid:{display:false}, ticks:{font:{size:10}, maxTicksLimit:14}}
    }
  }
});

// Contribution vs returns
new Chart(document.getElementById('contribChart'),{
  type:'bar',
  data:{labels,
    datasets:[
      {label:'Contributions / Withdrawals', data:contribVals, backgroundColor:contribVals.map(v=>v>=0?'rgba(30,42,58,0.65)':'rgba(196,75,43,0.65)'), borderRadius:2, stack:'a'},
      {label:'Investment Returns', data:growthVals, backgroundColor:'rgba(92,122,92,0.7)', borderRadius:2, stack:'a'}
    ]
  },
  options:{
    responsive:true,
    plugins:{legend:{labels:{font:{family:'Jost',size:11},color:'#5a4a38'}}},
    scales:{
      y:{stacked:true, grid:{color:'rgba(0,0,0,0.04)'}, ticks:{callback:v=>fK(v), font:{family:'Fira Mono',size:10}}},
      x:{stacked:true, grid:{display:false}, ticks:{font:{size:10}, maxTicksLimit:14}}
    }
  }
});

// Compare chart — this plan vs max savings (Plan B)
const maxSavings = [
  37000,69000,
  90000,94000,100000,106000,114000,122000,
  70000,68000,76000,82000,96000,108000,
  132000,140000,146000,152000,158000,162000,
  166000,172000,176000,180000,184000,186000,
  178000,176000,182000,188000,192000,194000,
  196000,198000,200000,200000,195000,188000,
  182000,176000,
  -90000,-92000,-94000,-96000,-98000,-90000
];
let maxPort = 20000;
const maxPortVals = [];
for(let i=0;i<43;i++){
  const c = maxSavings[i]||0;
  const g = Math.round((maxPort + c/2)*0.07);
  maxPort = maxPort + c + g;
  maxPortVals.push(maxPort);
}

new Chart(document.getElementById('compareChart'),{
  type:'line',
  data:{labels,
    datasets:[
      {label:'This Plan (Balanced Life)',data:portVals,borderColor:RUST,backgroundColor:'rgba(196,75,43,0.07)',borderWidth:2.5,fill:true,tension:0.4,pointRadius:2},
      {label:'Max Savings Plan (Plan B)',data:maxPortVals,borderColor:BONE,borderDash:[6,3],backgroundColor:'rgba(200,195,185,0.04)',borderWidth:1.5,fill:true,tension:0.4,pointRadius:0}
    ]
  },
  options:{
    responsive:true,
    plugins:{
      legend:{labels:{font:{family:'Jost',size:11},color:'#5a4a38'}},
      tooltip:{callbacks:{label:ctx=>` ${ctx.dataset.label}: ${ctx.raw>=1e6?fM(ctx.raw):fK(ctx.raw)}`}}
    },
    scales:{
      y:{grid:{color:'rgba(0,0,0,0.04)'},ticks:{callback:v=>v>=1e6?fM(v):fK(v),font:{family:'Fira Mono',size:10}}},
      x:{grid:{display:false},ticks:{font:{size:10},maxTicksLimit:14}}
    }
  }
});
